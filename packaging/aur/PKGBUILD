# Maintainer: Tiago Silva <tiagolsilva14 at gmail dot com>
#
# Before first upload:
#  - replace _repo_url with the real public repository URL, and fix _srcdir
#    if the repository name differs from $pkgname
#  - tag v$pkgver upstream, then run `updpkgsums` to fill sha256sums
#  - add a LICENSE file upstream and set license=() to match
#  - regenerate .SRCINFO: makepkg --printsrcinfo > .SRCINFO
pkgname=bincue-studio
pkgver=1.0.0
pkgrel=1
pkgdesc="Audio CD authoring studio — assemble tracks, export BIN/CUE, burn, and design labels (includes cdlabel)"
arch=('x86_64')
_repo_url="https://github.com/YOURUSER/bincue-studio"
url="$_repo_url"
license=('MIT')
depends=('qt6-base' 'qt6-svg' 'hostkit' 'taglib' 'ffmpeg')
makedepends=('cmake')
optdepends=('cdrdao: burn the exported BIN/CUE to disc')
source=("$pkgname-$pkgver.tar.gz::$_repo_url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')
_srcdir="$pkgname-$pkgver"

build() {
    cmake -B build -S "$_srcdir" \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DBINCUE_USE_SYSTEM_HOSTKIT=ON
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
}
