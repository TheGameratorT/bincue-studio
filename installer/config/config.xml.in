<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>BinCue Studio</Name>
    <Version>@PROJECT_VERSION@</Version>
    <Title>BinCue Studio Installer</Title>
    <Publisher>TheGameratorT</Publisher>
    <StartMenuDir>BinCue Studio</StartMenuDir>
    <TargetDir>@ApplicationsDir@/BinCue Studio</TargetDir>
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>
    <AllowSpaceInPath>true</AllowSpaceInPath>
    <WizardStyle>Modern</WizardStyle>
    <WizardDefaultWidth>800</WizardDefaultWidth>
    <WizardDefaultHeight>480</WizardDefaultHeight>
    <InstallerApplicationIcon>bincue-studio</InstallerApplicationIcon>
    <InstallerWindowIcon>installer-icon.png</InstallerWindowIcon>
</Installer>
